# Copy this file to .env and fill in your real values.
# Never commit your real .env — it's gitignored for a reason.

# Supabase — https://supabase.com/dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Serper.dev — https://serper.dev (free tier available)
SERPER_API_KEY=your_serper_api_key_here

# (Optional) Production frontend URL — used by CORS allow-list.
# In single-origin deploys (where the backend serves the SPA) this can stay empty.
FRONTEND_URL=

# (Optional) Override port for local dev. Cloud Run sets PORT=8080 automatically.
# PORT=3001
