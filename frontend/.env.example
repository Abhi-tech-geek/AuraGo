# Copy this file to .env.local and fill in your Supabase project's
# anon (publishable) key. The anon key is safe to expose to browsers
# because Supabase Row-Level-Security gates what it can read/write.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here
